# OpenAI API key voor ChatGPT-achtige gesprekken (VERPLICHT voor beste ervaring)
# Maak een .env bestand in de projectroot en plak je key hier:
OPENAI_API_KEY=sk-...

# Herstart daarna de dev server: npm run dev
# Zonder key werkt een beperkte lokale modus (geen echt AI-gesprek)

# Optioneel: ander model (standaard: gpt-4o-mini, alternatief: gpt-4o)
# OPENAI_MODEL=gpt-4o-mini

# Portal admin login (voor /admin/login) — fallback zonder Supabase Auth
VITE_PORTAL_ADMIN_EMAIL=admin@nexavo.works
VITE_PORTAL_ADMIN_PASSWORD_HASH=

# Supabase — productie klantportaal (nexavo.works)
# Zet deze op Vercel voor live sync tussen klantportaal en admin console
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Absolute site URL — voor SEO/canonical/share links en mail-links
VITE_APP_URL=https://nexavo.works

# Dev server poort (standaard 5173). Wijzig alleen als 5173 bezet is.
# VITE_DEV_PORT=5173

# E-mail (Resend) — server-side only, niet committen
RESEND_API_KEY=
MAIL_FROM=no-reply@nexavo.works
ADMIN_NOTIFICATION_EMAIL=
